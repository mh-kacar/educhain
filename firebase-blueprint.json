{
  "entities": {
    "Student": {
      "title": "Student",
      "description": "Details about a student in the school.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "grade": { "type": "string" },
        "email": { "type": "string" }
      },
      "required": ["id", "name", "grade"]
    },
    "Project": {
      "title": "Project",
      "description": "Details about a project or competition.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["Project", "Competition", "Seminar"] },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "type"]
    },
    "ParticipationRecord": {
      "title": "Participation Record",
      "description": "A single entry of a student joining a project/competition.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "projectId": { "type": "string" },
        "role": { "type": "string" },
        "achievement": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "projectId", "timestamp"]
    },
    "Block": {
      "title": "Blockchain Block",
      "description": "A block in the chain containing records.",
      "type": "object",
      "properties": {
        "index": { "type": "number" },
        "timestamp": { "type": "number" },
        "data": { "type": "array", "items": { "$ref": "#/entities/ParticipationRecord" } },
        "previousHash": { "type": "string" },
        "hash": { "type": "string" },
        "nonce": { "type": "number" }
      },
      "required": ["index", "timestamp", "data", "previousHash", "hash", "nonce"]
    }
  },
  "firestore": {
    "/students/{studentId}": {
      "schema": "Student",
      "description": "Stored students list"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "School projects and competitions"
    },
    "/blocks/{blockId}": {
      "schema": "Block",
      "description": "The scholastic chain blocks"
    }
  }
}
